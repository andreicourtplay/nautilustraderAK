IB_GATEWAY_HOST=127.0.0.1
# Leave blank to auto-detect TWS paper 7497 or IB Gateway paper 4002.
IB_GATEWAY_PORT=

# Use a different value per person when connecting to the same TWS/Gateway.
# If each person runs their own local TWS/Gateway, this can overlap, but unique
# IDs still make logs easier to read.
IB_CLIENT_ID=101
NAUTILUS_TRADER_ID=TRADER-YOURNAME

# Fill locally only. Never commit real values.
IB_ACCOUNT=DU1234567
TWS_ACCOUNT=DU1234567

IB_MAX_CONNECTION_ATTEMPTS=1
IB_CONNECTION_TIMEOUT=30
IB_REQUEST_TIMEOUT=20

IB_ORDER_SYMBOL=AAPL
IB_ORDER_ACTION=BUY
IB_ORDER_QUANTITY=1
IB_ORDER_TYPE=MKT
IB_ORDER_CURRENCY=USD
IB_ORDER_EXCHANGE=SMART
IB_ORDER_PRIMARY_EXCHANGE=NASDAQ
IB_ORDER_TIF=DAY

# Safety defaults for paper testing.
IB_REQUIRE_PAPER_ACCOUNT=true
IB_MAX_ORDER_QUANTITY=1
IB_ALLOWED_SYMBOLS=AAPL,IBKR

# First controlled strategy defaults.
IB_STRATEGY_SYMBOL=AAPL
IB_STRATEGY_SIDE=BUY
IB_STRATEGY_QUANTITY=1
IB_STRATEGY_ORDER_TYPE=MKT
